# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/nexvaulttrade?retryWrites=true&w=majority

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret

# Port (Render sets this automatically, but useful for local dev)
PORT=5000

# Comma-separated list of allowed frontend origins (no trailing slashes)
# Add your Render static site URL here after deploying the frontend
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Initial admin account — created automatically on first server start if no admin exists
ADMIN_EMAIL=oyeladetowobola@gmail.com
ADMIN_PASSWORD=kamala Harris
